# Runtime
NODE_ENV=production

# Server network
HOST=0.0.0.0
PORT=4000
API_PREFIX=/api/v1

# Repository + queue drivers
FAMILYCO_REPOSITORY_DRIVER=prisma
FAMILYCO_QUEUE_DRIVER=bullmq
ENABLE_QUEUE_WORKERS=1

# Database (required when FAMILYCO_REPOSITORY_DRIVER=prisma)
DB_PROVIDER=postgresql
DATABASE_URL=postgresql://familyco:change-me@127.0.0.1:5432/familyco

# Redis (required when FAMILYCO_QUEUE_DRIVER=bullmq)
REDIS_URL=redis://127.0.0.1:6379
FAMILYCO_QUEUE_NAME=familyco-jobs

# Security secrets (must not use local-dev defaults in production)
JWT_SECRET=replace-with-strong-secret
API_KEY_SALT=replace-with-strong-random-salt
FAMILYCO_API_KEY=replace-with-strong-api-key
