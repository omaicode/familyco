{
  "name": "@familyco/electron",
  "version": "1.0.0",
  "description": "FamilyCo Electron desktop shell",
  "homepage": "https://github.com/familyco/familyco",
  "type": "module",
  "main": "electron/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm run build && electron dist/electron/main.js",
    "build:renderer": "pnpm --filter @familyco/web build",
    "dist:desktop": "pnpm run build:renderer && pnpm run build && electron-builder --config ../../electron-builder.yml --publish never",
    "smoke": "tsx src/electron/smoke.ts",
    "test": "node -e \"console.log('No tests yet for @familyco/electron')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "familyco",
    "desktop"
  ],
  "author": {
    "name": "FamilyCo",
    "email": "thien.kt@omaicode.com"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@familyco/server": "workspace:*",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.12"
  }
}
