# ─────────────────────────────────────────────────────────────────────────────
# FamilyCo Renderer — Environment Configuration Example
# ─────────────────────────────────────────────────────────────────────────────
# These variables are injected by Vite at build time (prefix: VITE_).
# In Electron Desktop mode these values are set automatically via IPC/preload.
# Only needed when running the renderer standalone against an external server.
# ─────────────────────────────────────────────────────────────────────────────


# ── API Connection ────────────────────────────────────────────────────────────

# Base URL of the FamilyCo Fastify server the renderer will connect to.
# Development default points to the local embedded server.
# In production Electron builds this is set automatically — no need to change.
VITE_API_BASE_URL=http://127.0.0.1:4000

# API key used to authenticate requests from the renderer to the server.
# Must match FAMILYCO_API_KEY in the server's .env.
# Leave empty when running in Electron Desktop (injected via preload automatically).
VITE_API_KEY=replace-with-a-random-secret

# Bearer token for JWT-based authentication (optional, used alongside API key).
# Leave empty for local development — the server issues tokens after login.
VITE_BEARER_TOKEN=replace-with-a-random-secret
