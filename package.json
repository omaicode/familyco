{
  "name": "familyco",
  "version": "1.0.0",
  "description": "FamilyCo monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @familyco/electron run dist:desktop",
    "dev": "turbo run dev --parallel --filter=@familyco/server --filter=@familyco/web",
    "dev:desktop": "turbo run dev --parallel --filter=@familyco/web --filter=@familyco/electron",
    "dev:p": "turbo run dev --parallel",
    "prisma:generate": "pnpm --filter @familyco/server exec prisma generate --config ../../prisma.config.ts --schema ../../prisma/schema.prisma",
    "prisma:migrate:dev": "pnpm --filter @familyco/server exec prisma migrate dev --config ../../prisma.config.ts --schema ../../prisma/schema.prisma",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "keywords": [
    "familyco",
    "ai",
    "monorepo"
  ],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "axios": "^1.14.0",
    "dotenv": "^17.4.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.12.2"
  }
}