# ─────────────────────────────────────────────────────────────────────────────
# FamilyCo — Environment Configuration Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored at runtime.
# ─────────────────────────────────────────────────────────────────────────────


# ── Runtime ──────────────────────────────────────────────────────────────────

# Application environment.
# Values: development | production | test
NODE_ENV=development

# Port that the Fastify HTTP server listens on (Server Only / CLI mode).
# Not used in Electron Desktop — the embedded server always picks a free port.
PORT=4000

# URL prefix for all API routes.
API_PREFIX=/api/v1


# ── Storage / Database ───────────────────────────────────────────────────────

# Repository (database) driver to use.
# Values:
#   pglite  → Embedded PostgreSQL via PGlite (default, no server required).
#              Data is stored in PGLITE_DATA_DIR on the local filesystem.
#   prisma  → External PostgreSQL via Prisma + DATABASE_URL. Use for cloud/self-hosted.
#   memory  → In-memory only. Data is lost on restart. Useful for quick tests.
FAMILYCO_REPOSITORY_DRIVER=pglite

# Directory where PGlite stores its data files (only used when FAMILYCO_REPOSITORY_DRIVER=pglite).
# Use an absolute path in production. Relative paths are resolved from the process working directory.
# In Electron Desktop this is overridden automatically to the OS user-data folder:
#   Mac:     ~/Library/Application Support/FamilyCo/pgdata
#   Windows: C:\Users\<user>\AppData\Roaming\FamilyCo\pgdata
#   Linux:   ~/.config/FamilyCo/pgdata
PGLITE_DATA_DIR=./dev.pgdata

# PostgreSQL connection string.
# Required when FAMILYCO_REPOSITORY_DRIVER=prisma (external Postgres).
# Also used by Prisma CLI tools (prisma db push, prisma migrate diff, prisma studio).
# NOT used at runtime when FAMILYCO_REPOSITORY_DRIVER=pglite or memory.
DATABASE_URL=postgresql://localhost:5432/familyco


# ── Queue ────────────────────────────────────────────────────────────────────

# Job queue driver.
# Values:
#   memory  → In-process queue. No external dependency. Jobs are lost on restart.
#   bullmq  → Redis-backed queue. Requires REDIS_URL. Supports retries and persistence.
FAMILYCO_QUEUE_DRIVER=memory

# Redis connection URL (only used when FAMILYCO_QUEUE_DRIVER=bullmq).
REDIS_URL=redis://127.0.0.1:6379

# Name of the BullMQ queue (only used when FAMILYCO_QUEUE_DRIVER=bullmq).
FAMILYCO_QUEUE_NAME=familyco-jobs

# Whether to start BullMQ worker processes inside the server (0 = disabled, 1 = enabled).
# Enable only on dedicated worker nodes or when using bullmq queue driver.
ENABLE_QUEUE_WORKERS=0


# ── Authentication & Security ────────────────────────────────────────────────

# Internal API key used by the Desktop Electron shell to communicate with the
# embedded server. Also serves as the bootstrap API key on first run.
# ⚠️  Change this to a long random string in production (e.g. openssl rand -hex 32).
FAMILYCO_API_KEY=replace-with-a-random-secret

# Secret key used to sign JWT tokens for user sessions.
# ⚠️  Change this to a long random string in production (e.g. openssl rand -hex 32).
JWT_SECRET=replace-with-a-random-secret

# Salt used when hashing API keys before storing them in the database.
# ⚠️  Change this to a long random string in production (e.g. openssl rand -hex 32).
API_KEY_SALT=replace-with-a-random-secret
