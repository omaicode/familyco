# Runtime environment
NODE_ENV=development

# Database
DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Server
PORT=4000
API_PREFIX=/api/v1
FAMILYCO_REPOSITORY_DRIVER=memory
FAMILYCO_API_KEY=local-dev-api-key
FAMILYCO_QUEUE_DRIVER=memory
REDIS_URL=redis://127.0.0.1:6379
FAMILYCO_QUEUE_NAME=familyco-jobs
ENABLE_QUEUE_WORKERS=0

# Auth placeholders
JWT_SECRET=replace-with-local-dev-secret
API_KEY_SALT=replace-with-local-dev-salt
