generator client {
	provider   = "prisma-client"
	output = "../src/generated"
}

datasource db {
	provider = "sqlite"
}

model Agent {
	id            String   @id @default(cuid())
	name          String
	role          String
	level         String
	department    String
	status        String
	parentAgentId String?
	aiAdapterId   String?
	aiModel       String?
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	parent   Agent?  @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
	children Agent[] @relation("AgentHierarchy")

	ownedProjects    Project[]         @relation("ProjectOwner")
	assignedTasks    Task[]            @relation("TaskAssignee")
	createdTasks     Task[]            @relation("TaskCreator")
	approvalRequests ApprovalRequest[] @relation("ApprovalActor")
	agentRuns        AgentRun[]        @relation("AgentRootRuns")
	chatSessions     ChatSession[]
	budgetUsages     BudgetUsage[]     @relation("BudgetAgent")
}

model Project {
	id              String   @id @default(cuid())
	name            String
	description     String
	ownerAgentId    String
	parentProjectId String?
	dirPath         String?
	createdAt       DateTime @default(now())
	updatedAt       DateTime @updatedAt

	owner    Agent    @relation("ProjectOwner", fields: [ownerAgentId], references: [id])
	parent   Project? @relation("ProjectHierarchy", fields: [parentProjectId], references: [id])
	children Project[] @relation("ProjectHierarchy")
	tasks    Task[]
	budgetUsages BudgetUsage[] @relation("BudgetProject")
	agentRuns    AgentRun[]    @relation("RunProject")
}

model Task {
	id              String   @id @default(cuid())
	title           String
	description     String
	status          String
	priority        String   @default("medium")
	projectId       String
	assigneeAgentId String?
	createdBy       String
	dependsOnTaskIds Json    @default("[]")
	readinessRules   Json    @default("[]")
	createdAt       DateTime @default(now())
	updatedAt       DateTime @updatedAt

	project  Project @relation(fields: [projectId], references: [id])
	assignee Agent?  @relation("TaskAssignee", fields: [assigneeAgentId], references: [id])
	creator  Agent   @relation("TaskCreator", fields: [createdBy], references: [id])
	budgetUsages BudgetUsage[] @relation("BudgetTask")
	agentRuns    AgentRun[]    @relation("RunTask")
}

model ApprovalRequest {
	id        String   @id @default(cuid())
	actorId   String
	action    String
	targetId  String?
	status    String
	payload   Json?
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	actor Agent @relation("ApprovalActor", fields: [actorId], references: [id])
}

model AuditLog {
	id        String   @id @default(cuid())
	actorId   String
	action    String
	targetId  String?
	traceId   String?
	payload   Json?
	createdAt DateTime @default(now())
}

model AgentRun {
	id              String   @id @default(cuid())
	companyId       String?
	rootAgentId     String
	parentRunId     String?
	triggerType     String
	state           String
	inputSummary    String
	outputSummary   String?
	linkedProjectId String?
	linkedTaskId    String?
	startedAt       DateTime?
	finishedAt      DateTime?
	createdAt       DateTime @default(now())
	updatedAt       DateTime @updatedAt

	rootAgent Agent      @relation("AgentRootRuns", fields: [rootAgentId], references: [id])
	parentRun AgentRun?  @relation("AgentRunTree", fields: [parentRunId], references: [id])
	children  AgentRun[] @relation("AgentRunTree")
	project   Project?   @relation("RunProject", fields: [linkedProjectId], references: [id])
	task      Task?      @relation("RunTask", fields: [linkedTaskId], references: [id])
	budgetUsages BudgetUsage[]
	pluginRuns   PluginRun[]

	@@index([rootAgentId, createdAt])
	@@index([state, createdAt])
}

model BudgetUsage {
	id               String   @id @default(cuid())
	companyId        String?
	runId            String?
	agentId          String?
	projectId        String?
	taskId           String?
	provider         String
	model            String
	promptTokens     Int
	completionTokens Int
	totalTokens      Int
	estimatedCost    Float
	currency         String   @default("USD")
	recordedAt       DateTime @default(now())

	run     AgentRun? @relation(fields: [runId], references: [id])
	agent   Agent?    @relation("BudgetAgent", fields: [agentId], references: [id])
	project Project?  @relation("BudgetProject", fields: [projectId], references: [id])
	task    Task?     @relation("BudgetTask", fields: [taskId], references: [id])

	@@index([recordedAt])
	@@index([provider, model])
	@@index([runId])
}

model InboxMessage {
	id          String   @id @default(cuid())
	recipientId String
	senderId    String
	type        String
	title       String
	body        String
	status      String
	payload     Json?
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt
}

model ChatSession {
	id            String   @id @default(cuid())
	agentId       String
	founderId     String   @default("founder")
	title         String   @default("New chat")
	lastMessageAt DateTime @default(now())
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt

	agent    Agent         @relation(fields: [agentId], references: [id])
	messages ChatMessage[]

	@@index([agentId, founderId, lastMessageAt])
	@@index([agentId, createdAt])
}

model ChatMessage {
	id          String   @id @default(cuid())
	sessionId   String
	senderId    String
	recipientId String
	type        String
	title       String
	body        String
	payload     Json?
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt

	session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

	@@index([sessionId, createdAt])
	@@index([sessionId, senderId])
}

model Settings {
	id        String   @id @default(cuid())
	key       String   @unique
	value     Json
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
}

model ApiKey {
	id        String   @id @default(cuid())
	name      String
	keyHash   String   @unique
	active    Boolean  @default(true)
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
}

model TaskSessionCheckpoint {
	id               String   @id @default(cuid())
	taskId           String   @unique
	agentId          String
	sessionId        String
	checkpointIndex  Int      @default(0)
	status           String
	summary          String   @default("")
	lastToolNames    String   @default("[]")
	toolResults      String   @default("[]")
	startedAt        DateTime @default(now())
	updatedAt        DateTime @updatedAt

	@@index([agentId])
	@@index([status])
}

model Plugin {
	id             String   @id @default(cuid())
	name           String
	description    String
	version        String
	author         String?
	tags           Json     @default("[]")
	path           String   @unique
	entry          String
	capabilities   Json     @default("[]")
	state          String   @default("discovered")
	approvalMode   String   @default("require_review")
	checksum       String
	errorMessage   String?
	discoveredAt   DateTime @default(now())
	updatedAt      DateTime @updatedAt

	runs PluginRun[]

	@@index([state])
}

model PluginRun {
	id            String    @id @default(cuid())
	pluginId      String
	agentRunId    String?
	capability     String
	state         String
	inputJson     Json?
	outputJson    Json?
	errorMessage  String?
	startedAt     DateTime?
	finishedAt    DateTime?
	createdAt     DateTime  @default(now())

	plugin   Plugin    @relation(fields: [pluginId], references: [id])
	agentRun AgentRun? @relation(fields: [agentRunId], references: [id])

	@@index([pluginId, createdAt])
	@@index([agentRunId])
	@@index([state])
}
